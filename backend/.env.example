# GhostWatch backend — copy to .env and fill values (never commit .env).
#
# TigerGraph (TigerGraph Cloud or self-hosted)
# TG_HOST=https://your-instance.i.tgcloud.io   # must include http:// or https://
# TG_GRAPHNAME=ghostwatch
# TG_USERNAME=
# TG_PASSWORD=           # or use token-based auth per your deployment
# TG_SECRET=
# TG_RESTPP_PORT=443
# TG_SSL_VERIFY=true
#
# FastAPI
# API_HOST=0.0.0.0
# API_PORT=8000
# CORS_ORIGINS=http://localhost:5173
